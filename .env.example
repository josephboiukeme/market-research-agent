# ── Groq / LLM ────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama3-70b-8192

# ── Database ──────────────────────────────────────────────────────────────────
# Option A — SQLite (used by GitHub Actions; data persisted via artifacts)
DATABASE_URL=sqlite:///./data/market_agent.db

# Option B — local Postgres (for Ubuntu VM / production use)
# DATABASE_URL=postgresql+psycopg://market_agent:changeme@localhost:5432/market_agent

# ── SMTP email ────────────────────────────────────────────────────────────────
# Option A — unauthenticated local relay (Postfix on the same VM, no password needed)
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_TLS=false
SMTP_USER=
SMTP_PASSWORD=

# Option B — authenticated external relay (e.g. Gmail + App Password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_TLS=true
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your_app_password_here

EMAIL_FROM=market-agent@localhost
EMAIL_TO=you@example.com

# ── Watchlist (comma-separated tickers) ──────────────────────────────────────
WATCHLIST=SPY,QQQ,IWM,VTI,XLK,XLF,XLE

# ── Timezone ──────────────────────────────────────────────────────────────────
TIMEZONE=America/New_York
